rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
    }

    function isTeamOwner(teamId) {
      return isSignedIn() &&
        request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can read/write their own profile.
    // Team members can read each other's basic profile (needed for member lists).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ── User Teams map (userId → { teams, currentTeam, pendingInvites }) ─────
    match /userTeams/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Teams ─────────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Any member can read their team
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.members;

      // Only the owner can update/delete the team
      allow update, delete: if isTeamOwner(teamId);

      // Any authenticated user can create a team (they become owner)
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerId;
    }

    // ── Team Invites ──────────────────────────────────────────────────────────
    match /teamInvites/{inviteId} {
      // Invitee can read their own invite; team members can read invites for their team
      allow read: if isSignedIn();

      // Any team member can create an invite (UI restricts further)
      allow create: if isSignedIn();

      // Only the invitee (to accept/decline) or a team member can update
      allow update: if isSignedIn();

      // Only team owner can delete
      allow delete: if isSignedIn();
    }

    // ── Meetings ──────────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      // Allow read if user is a team member OR if it's their personal meeting
      allow read: if isSignedIn() && (
        (resource.data.teamId != null && isTeamMember(resource.data.teamId)) ||
        (resource.data.workspaceType == 'personal' && resource.data.uploadedBy == request.auth.uid) ||
        (resource.data.teamId == null && resource.data.uploadedBy == request.auth.uid)
      );

      // Allow create if uploading to a team they belong to, OR uploading personal meeting
      allow create: if isSignedIn() && (
        (request.resource.data.teamId != null && isTeamMember(request.resource.data.teamId)) ||
        (request.resource.data.workspaceType == 'personal' && request.resource.data.uploadedBy == request.auth.uid) ||
        (request.resource.data.teamId == null && request.resource.data.uploadedBy == request.auth.uid)
      );

      // Allow update if team member OR personal meeting
      allow update: if isSignedIn() && (
        (resource.data.teamId != null && isTeamMember(resource.data.teamId)) ||
        (resource.data.workspaceType == 'personal' && resource.data.uploadedBy == request.auth.uid) ||
        (resource.data.teamId == null && resource.data.uploadedBy == request.auth.uid)
      );

      // Only the uploader or team owner can delete
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.uploadedBy ||
        (resource.data.teamId != null && isTeamOwner(resource.data.teamId))
      );
    }

    // ── Slack Integrations ───────────────────────────────────────────────────
    match /slackIntegrations/{integrationId} {
      allow read: if isSignedIn() &&
        isTeamMember(resource.data.teamId);

      // Only Cloud Functions write to this collection directly;
      // client writes are managed via the manageSlackIntegration callable.
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
